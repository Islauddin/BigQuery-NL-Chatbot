GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# Comma-separated list of dataset IDs the chatbot is allowed to see/query
DATASET_WHITELIST=dataset1,dataset2

# Refuse to run any query estimated to scan more than this many bytes (100 MB default)
MAX_BYTES_BILLED=100000000

# Row limit auto-appended to generated queries that don't already have one
MAX_ROWS=1000
